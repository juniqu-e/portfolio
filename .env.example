# =============================================================================
# portfolio — Environment Variables (Template)
# =============================================================================
#
# 사용법:
#   1) 로컬 개발: 본 파일을 `.env.local` 로 복사 후 값 채우기
#        cp .env.example .env.local
#   2) 프로덕션(홈서버): docker-compose 와 같은 디렉토리의 `.env` 에 정의
#        (docker-compose.yml 의 `${VAR}` 가 자동 주입됨)
#
# 시크릿 생성:
#   openssl rand -hex 32         # ADMIN_TOKEN, IP_HASH_SALT 용 (64자 hex)
#
# ⚠️ 절대 `.env.local` / `.env` / 실제 값이 들어간 파일을 커밋하지 말 것.
#    `.gitignore` 에 이미 등록됨.
#
# ⚠️ `IP_HASH_SALT` 는 한번 정하면 변경 금지.
#    변경 시 기존 방명록의 IP hash 가 매칭 불가 → rate-limit / 어뷰즈 추적 무력화.
#    값 변경이 필요하면 별도 마이그레이션 절차 필요.
# =============================================================================


# -----------------------------------------------------------------------------
# Public — 브라우저로 노출됨 (NEXT_PUBLIC_ 접두어 필수)
# -----------------------------------------------------------------------------

# Google Analytics 4 측정 ID. 미설정 시 GA 스크립트 비활성화.
# 형식: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# 사이트 정식 URL (canonical). OG/메타데이터/sitemap 에 사용.
# leejunik.com 은 NPM 단에서 301 redirect 처리되므로 여기는 단일 정식 도메인.
NEXT_PUBLIC_SITE_URL=https://wnsdlr.com


# -----------------------------------------------------------------------------
# Server-only — 클라이언트 노출 금지
# -----------------------------------------------------------------------------

# 관리자 API 인증 토큰 (Bearer).
# DELETE /api/guestbook/:id, PATCH /api/guestbook/:id/approve 에서 사용.
# 32자 이상의 랜덤 문자열 권장.
ADMIN_TOKEN=

# IP 해시용 salt. 방명록 IP 는 raw 저장 X, SHA-256(ip + salt) 로 저장.
# 한번 정하면 변경 금지 (위 경고 참조). 32자 이상의 랜덤 문자열 권장.
IP_HASH_SALT=

# SQLite DB 파일 경로.
#   - 로컬:    ./data/guestbook.db  (또는 절대경로)
#   - Docker:  /data/guestbook.db    (portfolio-data volume 마운트 지점)
DB_PATH=/data/guestbook.db

# Rate limit 윈도우 (ms). 기본 5분 = 300000.
RATE_LIMIT_WINDOW_MS=300000

# Rate limit 윈도우당 허용 요청 수. 기본 1 (5분당 1회).
RATE_LIMIT_MAX_REQUESTS=1


# -----------------------------------------------------------------------------
# Runtime (보통 Docker / Next.js 가 자동 설정 — 로컬 override 시만 사용)
# -----------------------------------------------------------------------------

# NODE_ENV=production
# PORT=3000
